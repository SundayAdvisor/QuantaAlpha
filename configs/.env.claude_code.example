# =============================================================================
# QuantaAlpha environment — Claude Code subscription mode
#
# Use this template when you want to route LLM calls through your local
# Claude Code session (drains your Max subscription instead of paying per
# token to a third-party LLM API).
#
# Setup:
#   1. cp configs/.env.claude_code.example .env
#   2. Edit QLIB_DATA_DIR and DATA_RESULTS_DIR below for your machine
#   3. Make sure you've run `claude login` (or signed into Claude Code)
#   4. Install: pip install claude-agent-sdk
#   5. Run the smoke test: python scratch/claude_smoke.py
#   6. Once smoke passes, run a tiny experiment:
#        python launcher.py mine --direction "test"
#
# See QUANTAALPHA_RUN_GUIDE.md (in the workspace root) for the full guide.
# =============================================================================

# =============================================================================
# Paths (REQUIRED — set these for your machine)
# =============================================================================

# Qlib data directory (must contain calendars/, features/, instruments/)
QLIB_DATA_DIR=<your_qlib_data_path>

# Output root (results, cache, logs)
DATA_RESULTS_DIR=<your_results_path>

QLIB_PROVIDER_URI=<your_qlib_data_path>
CONDA_ENV_NAME=quantaalpha

# =============================================================================
# LLM provider — Claude Code subscription
# =============================================================================
# When llm_provider=claude_code, all LLM calls go through the local Claude
# Code session. No API key is needed for the primary path; auth comes from
# `claude login`.
LLM_PROVIDER=claude_code

# Which Claude model the session should use. Leave blank to inherit Claude
# Code's default (whatever model your subscription is configured for).
# Common values: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5
CLAUDE_CODE_MODEL=claude-sonnet-4-6

# Per-session turn cap before rotating to a fresh session. Higher = better
# context cache reuse; lower = freer recovery from poisoned context.
CLAUDE_CODE_MAX_TURNS_PER_SESSION=30

# After a rate-limit-classified error, wait this many seconds before retrying
# the primary backend. The fallback (if configured) handles calls during
# cooldown.
CLAUDE_CODE_RATE_LIMIT_COOLDOWN=300

# Bypass tool-permission prompts. Always true; we want pure inference, not
# Claude Code reaching for Bash/Read/Write/etc.
CLAUDE_CODE_DISABLE_TOOLS=true

# =============================================================================
# Fallback chain (when subscription is exhausted)
# =============================================================================
# Choices:
#   anthropic  -> use Anthropic API direct (pay per token; needs ANTHROPIC_API_KEY)
#   openai     -> use the OPENAI_BASE_URL block below (DeepSeek/local Ollama/etc.)
#   none       -> raise on rate limit; no fallback
CLAUDE_CODE_FALLBACK=anthropic

# Used only when CLAUDE_CODE_FALLBACK=anthropic. Get from console.anthropic.com.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Used only when CLAUDE_CODE_FALLBACK=openai. Point at any OpenAI-compatible
# endpoint (DeepSeek, OpenRouter, local Ollama, etc.).
OPENAI_API_KEY=
OPENAI_BASE_URL=
CHAT_MODEL=
REASONING_MODEL=

# =============================================================================
# Embedding (Claude has no embedding API)
# =============================================================================
# QuantaAlpha's CoSTEER knowledge base needs embeddings. Two options:
#   (a) Point these at OpenAI / DashScope / Voyage. Embeddings are cheap
#       (~$0.02 / 1M tokens). Recommended.
#   (b) Leave blank — CoSTEER will run with reduced self-correction quality.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Global (usually no need to change)
# =============================================================================
USE_LOCAL=True
MAX_RETRY=5
RETRY_WAIT_SECONDS=5
FACTOR_MINING_TIMEOUT=999999
CHAT_MAX_TOKENS=4000
CHAT_TEMPERATURE=0.7
